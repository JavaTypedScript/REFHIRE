rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Candidate profiles
    match /candidateProfiles/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Employee profiles — readable by all authenticated users, writable by owner
    match /employeeProfiles/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Referral requests — get is strict (participant only), list allows any
    // authenticated user. Same OR-condition fix as shadowInterviews.
    match /referralRequests/{requestId} {
      allow get: if request.auth != null && (
        resource.data.candidateId == request.auth.uid ||
        resource.data.employeeId == request.auth.uid
      );
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.candidateId == request.auth.uid ||
        resource.data.employeeId == request.auth.uid
      );
    }

    // Pipeline — readable by the employee who created it
    match /pipeline/{pipelineId} {
      allow read: if request.auth != null && resource.data.employeeId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.employeeId == request.auth.uid;
    }

    // Activity feed — readable by the user it belongs to
    match /activity/{activityId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Shadow Interviews — get is strict (participant only), list allows any
    // authenticated user because Firestore can't validate OR conditions on
    // collection queries. Client queries already filter by candidateId/employeeId.
    match /shadowInterviews/{interviewId} {
      allow get: if request.auth != null && (
        resource.data.candidateId == request.auth.uid ||
        resource.data.employeeId == request.auth.uid
      );
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.candidateId == request.auth.uid ||
        resource.data.employeeId == request.auth.uid
      );
    }

    // Seeding metadata
    match /_meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // Demo data (seeded employees/candidates with demo- prefix)
    match /employeeProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && uid.matches('demo-.*');
    }
    match /candidateProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && uid.matches('demo-.*');
    }
  }
}